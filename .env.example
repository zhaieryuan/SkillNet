# SkillNet 环境变量配置文件
# 复制此文件为 .env 并填写您的配置

# ==============================================================================
# OpenAI API 配置（创建、评估、分析功能必需）
# ==============================================================================

# OpenAI API Key（必需）
# 获取方式: https://platform.openai.com/api-keys
# 用于: skillnet create, skillnet evaluate, skillnet analyze
API_KEY=sk-your-openai-api-key-here

# OpenAI API Base URL（可选）
# 默认值: https://api.openai.com/v1
# 使用场景:
#   - 使用代理服务
#   - 使用兼容 OpenAI API 的第三方服务（如 Azure OpenAI）
#   - 使用自部署的 LLM 服务
# BASE_URL=https://api.openai.com/v1

# 国内代理示例（如果 OpenAI API 无法直接访问）：
# BASE_URL=https://api.openai-proxy.com/v1

# Azure OpenAI 示例：
# BASE_URL=https://your-resource.openai.azure.com/openai/deployments/your-deployment

# ==============================================================================
# 模型配置
# ==============================================================================

# 默认使用的 LLM 模型
# 默认值: gpt-4o
#
# 推荐模型（按性能和成本排序）:
#
# 【推荐】OpenAI GPT-4o 系列（最佳性价比）:
#   - gpt-4o (默认) - 最新旗舰模型，性能强，成本合理
#   - gpt-4o-2024-11-20 - 指定版本，稳定性好
#   - gpt-4o-mini - 轻量版，速度快，成本低，适合简单任务
#
# OpenAI GPT-4 系列（高性能）:
#   - gpt-4-turbo - GPT-4 加速版，128K 上下文
#   - gpt-4 - 经典版本，推理能力强
#
# OpenAI GPT-3.5 系列（经济型）:
#   - gpt-3.5-turbo - 快速且便宜，适合简单任务
#
# Claude 系列（需配置 BASE_URL）:
#   - claude-3-5-sonnet-20241022 - 最新 Claude 模型
#   - claude-3-opus-20240229 - 最强推理能力
#   - claude-3-sonnet-20240229 - 平衡性能和成本
#
# 国产模型（需配置对应的 BASE_URL）:
#   - qwen-max - 阿里通义千问
#   - glm-4 - 智谱清言
#   - ERNIE-4.0-8K - 百度文心一言
#
SKILLNET_MODEL=gpt-4o

# 不同场景的模型推荐：
#
# 创建技能 (skillnet create):
#   推荐: gpt-4o, gpt-4-turbo
#   原因: 需要理解复杂上下文并生成高质量代码
#
# 评估技能 (skillnet evaluate):
#   推荐: gpt-4o, gpt-4o-mini
#   原因: 需要多维度分析，但不需要生成大量内容
#
# 分析关系 (skillnet analyze):
#   推荐: gpt-4o-mini, gpt-3.5-turbo
#   原因: 主要是分类和匹配任务，轻量模型即可
#
# 搜索和下载:
#   不需要 LLM，无需配置 API_KEY

# ==============================================================================
# GitHub 配置（可选，但强烈推荐）
# ==============================================================================

# GitHub Personal Access Token（可选）
# 获取方式: https://github.com/settings/tokens
# 权限需求: repo (访问私有仓库), public_repo (公开仓库足够)
#
# 作用:
#   1. 提高 GitHub API 速率限制（从 60/小时 提升到 5000/小时）
#   2. 访问私有仓库
#   3. 避免下载时 API 限流
#
# GITHUB_TOKEN=ghp_your_github_token_here

# GitHub 镜像地址（国内加速）
# 用于加速 GitHub 仓库克隆和下载
#
# 推荐镜像:
#   - https://ghfast.top/          (推荐，速度快)
#   - https://mirror.ghproxy.com/  (备用)
#   - https://github.moeyy.xyz/    (备用)
#
# 使用方式:
#   自动在 GitHub URL 前添加镜像地址
#   例如: https://github.com/... → https://ghfast.top/https://github.com/...
#
# GITHUB_MIRROR=https://ghfast.top/

# ==============================================================================
# API 服务器配置（仅 Web API 使用）
# ==============================================================================

# 服务器监听地址
# 默认值: 0.0.0.0 (监听所有网络接口)
#
# 选项:
#   - 0.0.0.0 : 允许外部访问（生产环境）
#   - 127.0.0.1 : 仅本机访问（开发环境，更安全）
#
HOST=0.0.0.0

# 服务器端口
# 默认值: 8000
# 推荐端口: 8000, 8080, 3000
PORT=8000

# 自动重载（开发模式）
# 默认值: true
# 选项:
#   - true : 代码变更自动重启（开发环境）
#   - false : 不自动重启（生产环境）
#
RELOAD=true

# ==============================================================================
# 高级配置（通常无需修改）
# ==============================================================================

# OpenAI 组织 ID（可选）
# 仅在使用组织账号时需要
# OPENAI_ORG_ID=org-your-org-id

# 请求超时时间（秒）
# 用于 API 请求的超时设置
# REQUEST_TIMEOUT=60

# 日志级别
# 选项: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# ==============================================================================
# 使用示例
# ==============================================================================
#
# 最小配置（仅搜索和下载）:
#   无需配置任何变量，开箱即用！
#
# 基础配置（创建、评估功能）:
#   API_KEY=sk-...
#   SKILLNET_MODEL=gpt-4o
#
# 完整配置（所有功能 + 最佳体验）:
#   API_KEY=sk-...
#   SKILLNET_MODEL=gpt-4o
#   GITHUB_TOKEN=ghp_...
#   GITHUB_MIRROR=https://ghfast.top/
#   HOST=0.0.0.0
#   PORT=8000
#
# ==============================================================================
# 成本参考（OpenAI 官方定价，2024年）
# ==============================================================================
#
# gpt-4o:
#   输入:  $2.50 / 1M tokens
#   输出:  $10.00 / 1M tokens
#
# gpt-4o-mini:
#   输入:  $0.150 / 1M tokens
#   输出:  $0.600 / 1M tokens
#
# gpt-4-turbo:
#   输入:  $10.00 / 1M tokens
#   输出:  $30.00 / 1M tokens
#
# gpt-3.5-turbo:
#   输入:  $0.50 / 1M tokens
#   输出:  $1.50 / 1M tokens
#
# 预估成本（创建一个中等复杂度技能）:
#   使用 gpt-4o: $0.05 - $0.20
#   使用 gpt-4o-mini: $0.01 - $0.05
#
# ==============================================================================
# 安全提示
# ==============================================================================
#
# ⚠️ 重要: 不要将 .env 文件提交到 Git 仓库
# ⚠️ 已配置: .env 文件已在 .gitignore 中排除
# ⚠️ 建议: 定期轮换 API Key 和 Token
# ⚠️ 提醒: 不要在公开代码中硬编码密钥
#
# ==============================================================================
